PORT=3001
NODE_ENV=development

# AlienVault OTX - https://otx.alienvault.com
OTX_API_KEY=your_otx_api_key_here

# NVD CVEs - https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# PhishTank - https://www.phishtank.com/api_info.php
PHISHTANK_API_KEY=your_phishtank_key_here

# Shodan - https://account.shodan.io (free tier available)
SHODAN_API_KEY=your_shodan_api_key_here

# HaveIBeenPwned - https://haveibeenpwned.com/API/Key
HIBP_API_KEY=your_hibp_api_key_here

# Monitoring: how often to auto-scan (hours)
SCAN_INTERVAL_HOURS=6

# Cache TTL (seconds)
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=900
CACHE_TTL_LONG=3600
